{
  "expo": {
    "name": "SPARK LOG",
    "slug": "sparknotes",
    "scheme": "sparklog",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.sparklog.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_BACKGROUND_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "ios": {
      "bundleIdentifier": "com.sparklog.app",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "需要定位權限以提供雷店接近提醒",
        "NSLocationWhenInUseUsageDescription": "需要定位權限以記錄店家位置",
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "需要定位權限以提供雷店接近提醒"
        }
      ],
      "expo-notifications",
      "expo-asset",
      "expo-sharing",
      "./plugins/withAndroidLargeHeap.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "48b06465-1c6c-4b1f-a3df-3ad598f1e18b"
      }
    },
    "owner": "mimichild",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/48b06465-1c6c-4b1f-a3df-3ad598f1e18b"
    }
  }
}
